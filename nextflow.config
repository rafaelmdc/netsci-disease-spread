// Nextflow runs every process inside the project image, so pipeline and
// interactive runs are byte-identical. Build it first: `docker compose build`.

docker.enabled = true

process {
    container = 'netsci-disease-spread:latest'
}

profiles {
    // local laptop run in the active environment (conda `datascience`):
    // run `netsci` directly, no container.
    local {
        process.executor = 'local'
        docker.enabled = false
    }
    // example HPC profile (fill queue/resources for your cluster)
    cluster {
        process.executor = 'slurm'
    }
}

// Reproducibility: a timestamped report + DAG per run.
report.enabled = true
dag.enabled = true
