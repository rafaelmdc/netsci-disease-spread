// Self-contained run: every process runs inside the project image, so the
// only host prerequisites are Docker and Nextflow. Build the image first with
// `docker compose build` (or `make run`, which does it for you).

docker.enabled = true
docker.runOptions = '-u $(id -u):$(id -g)'   // write artifacts as the host user

process {
    container = 'netsci-disease-spread:latest'

    // `netsci` resolves data/ + results/ relative to its own source (-> /app
    // inside the image, see src/paths.py), so bind-mount the host artifact dirs
    // onto /app. Every stage then shares state and outputs land on the host.
    // --entrypoint '' clears the image ENTRYPOINT (`netsci`) so Nextflow's own
    // /bin/bash wrapper runs the process script. (Compose still uses it.)
    // projectDir is the main-script dir (workflow/); the repo root is one up.
    containerOptions = "-v ${projectDir}/../data:/app/data " +
                       "-v ${projectDir}/../results:/app/results " +
                       "-v ${projectDir}/../figures:/app/figures " +
                       "-v ${projectDir}/../vendor:/app/vendor " +
                       "--entrypoint ''"
}

profiles {
    // Local laptop run in the active environment (e.g. conda `datascience`):
    // run `netsci` directly, no container.
    local {
        process.executor = 'local'
        process.container = ''
        docker.enabled = false
    }
    // Example HPC profile (fill queue/resources for your cluster).
    cluster {
        process.executor = 'slurm'
    }
}

// Reproducibility: a timestamped report + DAG per run.
report.enabled = true
dag.enabled = true
