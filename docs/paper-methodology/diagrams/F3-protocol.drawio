<mxfile host="app.diagrams.net" type="device">
  <diagram id="F3protocol" name="F3 Experimental protocol">
    <mxGraphModel dx="1100" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1060" pageHeight="430" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Experimental protocol" style="text;html=1;fontSize=17;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="330" y="10" width="400" height="28" as="geometry" />
        </mxCell>

        <!-- shared start: the substrate, feeds both lanes -->
        <mxCell id="start" value="&lt;b&gt;Multilayer&lt;br&gt;network&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#888888;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="176" width="140" height="100" as="geometry" />
        </mxCell>

        <!-- ===== Lane A: node targeting (vaccination) ===== -->
        <mxCell id="laneA" value="&lt;b&gt;Node targeting&amp;nbsp;&amp;mdash;&amp;nbsp;vaccination&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fillColor=#eef7ea;strokeColor=#82b366;fontSize=13;fontColor=#4e7a32;" vertex="1" parent="1">
          <mxGeometry x="210" y="52" width="830" height="150" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="&lt;b&gt;1&amp;nbsp;&amp;middot;&amp;nbsp;Spread&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;no intervention;&lt;br&gt;how it spreads&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#dae8fc;strokeColor=#6c8ebf;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="226" y="104" width="176" height="84" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="&lt;b&gt;2&amp;nbsp;&amp;middot;&amp;nbsp;Vaccinate&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;compare targeting rules;&lt;br&gt;keep the best&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#d5e8d4;strokeColor=#82b366;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="430" y="104" width="176" height="84" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="&lt;b&gt;3&amp;nbsp;&amp;middot;&amp;nbsp;Re-check&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;best rule on the&lt;br&gt;other disease types&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#d5e8d4;strokeColor=#82b366;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="634" y="104" width="176" height="84" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="&lt;b&gt;4&amp;nbsp;&amp;middot;&amp;nbsp;Dose&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;sweep the winner's budget:&lt;br&gt;how many cities?&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#fff2cc;strokeColor=#d6b656;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="838" y="104" width="176" height="84" as="geometry" />
        </mxCell>
        <mxCell id="aS12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block;html=1;strokeColor=#666666;labelBackgroundColor=none;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aS23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block;html=1;strokeColor=#666666;labelBackgroundColor=none;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aS34" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block;html=1;strokeColor=#666666;labelBackgroundColor=none;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s3" target="s4"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== Lane B: edge targeting (interdiction) ===== -->
        <mxCell id="laneB" value="&lt;b&gt;Edge targeting&amp;nbsp;&amp;mdash;&amp;nbsp;interdiction&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fillColor=#f3eef7;strokeColor=#9673a6;fontSize=13;fontColor=#6a4c93;" vertex="1" parent="1">
          <mxGeometry x="210" y="250" width="830" height="150" as="geometry" />
        </mxCell>
        <mxCell id="i1" value="&lt;b&gt;Full network&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;no routes closed;&lt;br&gt;baseline&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="333" y="302" width="176" height="84" as="geometry" />
        </mxCell>
        <mxCell id="i2" value="&lt;b&gt;Close air&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ground every flight;&lt;br&gt;land + water remain&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="537" y="302" width="176" height="84" as="geometry" />
        </mxCell>
        <mxCell id="i3" value="&lt;b&gt;Also close ferries&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;shut water routes too;&lt;br&gt;only land left&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="741" y="302" width="176" height="84" as="geometry" />
        </mxCell>
        <mxCell id="aI12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block;html=1;strokeColor=#666666;labelBackgroundColor=none;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="i1" target="i2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aI23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block;html=1;strokeColor=#666666;labelBackgroundColor=none;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="i2" target="i3"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- start splits into the two LANES (points at the lane blocks) -->
        <mxCell id="toA" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block;html=1;strokeColor=#888888;labelBackgroundColor=none;exitX=1;exitY=0.3;entryX=0;entryY=0.5;" edge="1" parent="1" source="start" target="laneA"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="toB" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=block;html=1;strokeColor=#888888;labelBackgroundColor=none;exitX=1;exitY=0.7;entryX=0;entryY=0.5;" edge="1" parent="1" source="start" target="laneB"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
