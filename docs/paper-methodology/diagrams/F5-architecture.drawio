<mxfile host="app.diagrams.net" type="device">
  <diagram id="F5arch" name="F5 — System architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1120" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="System architecture: two front ends, one shared core" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="310" y="10" width="500" height="30" as="geometry" />
        </mxCell>

        <!-- Config -->
        <mxCell id="cfg" value="experiment.yaml&#10;(single source of truth: regions × layers ×&#10;disease types × strategies × coverages × seeds)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="380" y="55" width="360" height="50" as="geometry" />
        </mxCell>

        <!-- BATCH front end -->
        <mxCell id="batchBox" value="BATCH front end" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;spacingTop=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="300" height="150" as="geometry" />
        </mxCell>
        <mxCell id="cli" value="Typer CLI&#10;(retrieve · netgen · evaluate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="65" y="190" width="250" height="44" as="geometry" />
        </mxCell>
        <mxCell id="nf" value="Nextflow&#10;(parallel sweep + caching)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="65" y="244" width="250" height="44" as="geometry" />
        </mxCell>

        <!-- INTERACTIVE front end -->
        <mxCell id="webBox" value="INTERACTIVE front end (simulator)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;spacingTop=6;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="150" width="300" height="230" as="geometry" />
        </mxCell>
        <mxCell id="browser" value="Browser&#10;(design scenario · live curve + map)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="805" y="190" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="fastapi" value="FastAPI + Uvicorn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="805" y="244" width="250" height="34" as="geometry" />
        </mxCell>
        <mxCell id="redis" value="Redis  (arq job queue + pub/sub)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="805" y="290" width="250" height="34" as="geometry" />
        </mxCell>
        <mxCell id="worker" value="arq worker  (runs one sim)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="805" y="336" width="250" height="34" as="geometry" />
        </mxCell>

        <!-- CORE -->
        <mxCell id="core" value="SHARED CORE&#10;pipeline + epidemic engine (Python · NumPy · NetworkX)&#10;a run = pure function of (config, seed)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;spacingTop=8;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="430" width="360" height="90" as="geometry" />
        </mxCell>

        <!-- artifacts -->
        <mxCell id="nets" value="networks&#10;GraphML" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="300" y="580" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="res" value="results&#10;JSON · Parquet" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="500" y="580" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="figs" value="figures (Plotly)&#10;+ Gephi export" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="700" y="580" width="120" height="70" as="geometry" />
        </mxCell>

        <!-- docker note -->
        <mxCell id="docker" value="containerised with Docker / docker-compose (web app · worker · Redis)" style="text;html=1;fontSize=10;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="320" y="685" width="480" height="20" as="geometry" />
        </mxCell>

        <!-- edges: config to front ends -->
        <mxCell id="e_cfg_b" style="endArrow=block;html=1;strokeColor=#666666;" edge="1" parent="1" source="cfg" target="batchBox"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_cfg_w" style="endArrow=block;html=1;strokeColor=#666666;" edge="1" parent="1" source="cfg" target="webBox"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- interactive internal flow -->
        <mxCell id="e_br_api" value="design / request" style="endArrow=block;html=1;fontSize=9;" edge="1" parent="1" source="browser" target="fastapi"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_api_redis" value="enqueue job" style="endArrow=block;html=1;fontSize=9;" edge="1" parent="1" source="fastapi" target="redis"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_redis_wk" style="endArrow=block;html=1;fontSize=9;" edge="1" parent="1" source="redis" target="worker"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_stream" value="per-day events → pub/sub → SSE → live view" style="endArrow=block;html=1;dashed=1;strokeColor=#b85450;fontSize=9;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" edge="1" parent="1" source="worker" target="browser">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1100" y="353" /><mxPoint x="1100" y="210" /></Array></mxGeometry>
        </mxCell>

        <!-- front ends to core -->
        <mxCell id="e_b_core" value="run" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="batchBox" target="core"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_w_core" value="run" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="worker" target="core"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- core to artifacts -->
        <mxCell id="e_c_n" style="endArrow=open;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="core" target="nets"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_c_r" style="endArrow=open;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="core" target="res"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_c_f" style="endArrow=open;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="core" target="figs"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
